# Option A: path to the service account JSON file (recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json

# Option B: paste the entire service account JSON as one line (e.g. in cloud hosting)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
set FIREBASE_SERVICE_ACCOUNT (JSON string) or GOOGLE_APPLICATION_CREDENTIALS (path to service account file)
PORT=3000
